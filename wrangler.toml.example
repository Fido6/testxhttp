name = "dovssaaa"
main = "worker.ts"
compatibility_date = "2026-05-17"

[durable_objects]
bindings = [
  { name = "NEST", class_name = "SessionDO" }
]

[[migrations]]
tag = "v1"
new_sqlite_classes = ["SessionDO"]

[vars]
# IMPORTANT: change this UUID to your own
K_SIGIL = "58888888-8888-8888-8888-888888888888"
# Path segment for your endpoint, e.g. /xhttp/<sid>
P_SIGIL = "xhttp"
# Optional upstream proxy / reverse proxy.
# Supported schemes: tcp://host:port, http://host:port, https://host:port, socks5://host:port
# With auth: http://user:pass@host:port or socks5://user:pass@host:port
PROXY_URL = ""
